# ===========================================
# SQL EXAM SYSTEM - Environment Variables
# ===========================================

# ========== SERVER ==========
ENVIRONMENT=development
HTTP_PORT=8080

# ========== SYSTEM DATABASE (PostgreSQL - Main) ==========
DATABASE_USER=postgres
DATABASE_PASSWORD=123456
DATABASE_NAME=sql_exam_db
DATABASE_URI=postgres://postgres:123456@localhost:5432/sql_exam_db?sslmode=disable

# ========== SANDBOX DATABASES (Query Execution) ==========
SANDBOX_PASSWORD=123456
SANDBOX_POSTGRES_URI=postgres://sandbox:123456@localhost:5433/sandbox_db?sslmode=disable
SANDBOX_MYSQL_URI=mysql://sandbox:123456@localhost:3307/sandbox_db
SANDBOX_SQLSERVER_URI=sqlserver://sa:123456@localhost:1434?database=sandbox_db

# ========== QUERY EXECUTION LIMITS ==========
QUERY_TIMEOUT_SECONDS=5
QUERY_MAX_ROWS=1000

# ========== CACHING (Redis) ==========
REDIS_URI=localhost:6379
REDIS_PASSWORD=redis123
REDIS_DB=0

# ========== EVENT STREAMING (Kafka) ==========
KAFKA_ENABLED=true
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=chamsql-backend

# ========== AUTHENTICATION (JWT) ==========
# Base64 encoded secret: Vm1wS01HRXhTWGROU0d4VVltdHdWRmx0ZUdGV1ZsbDNWbTVrYTAxWGREWlhhMmhoVlZaV1ZVMUVhejA9
AUTH_SECRET=Vm1wS01HRXhTWGROU0d4VVltdHdWRmx0ZUdGV1ZsbDNWbTVrYTAxWGREWlhhMmhoVlZaV1ZVMUVhejA9
ACCESS_TOKEN_DURATION=150m
REFRESH_TOKEN_DURATION=168h

# ========== OBJECT STORAGE (MinIO) ==========
MINIO_ENDPOINT=sqlexam.minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=chamsql
MINIO_BASE_URL=http://sqlexam.minio:9000
MINIO_PUBLIC_BASE_URL=http://localhost:9000
MINIO_USE_SSL=false

# ========== AI/ML SERVICES (Phase 4 - Optional) ==========
HUGGINGFACE_API_KEY=
OPENAI_API_KEY=sk-...key thật...
OPENAI_MODEL=gpt-4o-mini
AI_PROVIDER=openai

# ========== CORS ==========
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
